 Budgets"},{"parameters":{"jsCode":"// 1. Acessa o JSON limpo do node \"Code in JavaScript\"\n// (Certifique-se que o nome do node anterior é exatamente \"Code in JavaScript\")\nconst aiOutput = $('Code in JavaScript').first().json; \n\nconst targetCategory = aiOutput.category.toLowerCase();\n\n// 2. Acessa a lista de budgets (que veio do input deste node \"Listar Budgets\")\nconst budgets = items.map(item => item.json);\n\n// 3. Procura se já existe um budget com essa categoria\nconst match = budgets.find(b => b.category.toLowerCase() === targetCategory);\n\nif (match) {\n  // Se achou, retorna o ID para editar\n  return [{\n    json: {\n      id: match.id,\n      new_limit: aiOutput.amount,\n      action: aiOutput.type\n    }\n  }];\n}\n\nif (aiOutput.type === 'budget_create') {\n  // Se não achou e é para criar, marca como NEW\n  return [{\n    json: {\n      id: 'NEW',\n      new_limit: aiOutput.amount,\n      action: aiOutput.type\n    }\n  }];\n}\n\n// Se tentou editar algo que não existe\nthrow new Error(`Não encontrei nenhum orçamento para a categoria: ${targetCategory}`);"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[-368,896],"id":"68d69b59-5fa1-4446-ae4a-081b08d028a7","name":"Achar ID"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":3},"conditions":[{"id":"332cb458-426d-44d9-ac6d-fae1d42824ee","leftValue":"={{ $('AI Agent').first().item.json.output }}","rightValue":"budget_update","operator":{"type":"string","operation":"regex"}}],"combinator":"and"},"options":{}},"type":"n8n-nodes-base.if","typeVersion":2.3,"position":[-144,896],"id":"c34df15a-c032-42a0-a2b2-2257beae7118","name":"Editar ou Apagar?"},{"parameters":{"method":"DELETE","url":"=https://finanzas.ktuche.com/transactions/{{ $json.id }}","options":{"allowUnauthorizedCerts":true}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.3,"position":[-368,512],"id":"36e61fce-83ba-4e66-a384-79e7f729fd53","name":"Deletar Transa