ecipientPhoneNumber":"={{ $('WhatsApp Trigger').item.json.contacts[0].wa_id }}","textBody":"=✅ *{{ $('Code in JavaScript').item.json.type == 'income' ? 'Ingreso' : 'Gasto' }} Registrado!*\n\n📝 {{ $('Code in JavaScript').item.json.description }}\n💰 ${{ $('Code in JavaScript').item.json.amount }}\n📂 {{ $('Code in JavaScript').item.json.category }}\n\n","additionalFields":{}},"type":"n8n-nodes-base.whatsApp","typeVersion":1.1,"position":[-368,320],"id":"2855f25f-60b1-4a3c-9496-6cf04c7e4bcd","name":"Mensagem de confirmação do cadastro1","webhookId":"e461be41-37b4-41f7-a7e4-78d895161a34","credentials":{"whatsAppApi":{"id":"Jl5aH7LJ3O7m8M3p","name":"WhatsApp account"}},"disabled":true},{"parameters":{"operation":"send","phoneNumberId":"914691621734879","recipientPhoneNumber":"={{ $('WhatsApp Trigger').first().json.contacts[0].wa_id }}","textBody":"=📊 *RELATÓRIO FINANCEIRO*\n\n💰 *Total Entradas:* {{ $json.total_income }}\n💸 *Total Saídas:* {{ $json.total_expenses }}\n━━━━━━━━━━━━━━━━━━\n🏦 *SALDO ATUAL:* *{{ $json.balance }}*\n━━━━━━━━━━━━━━━━━━\n\n💡 *Dica:* {{ $json.ai_advice_message }}","additionalFields":{}},"type":"n8n-nodes-base.whatsApp","typeVersion":1.1,"position":[-144,1568],"id":"f051d3e0-b043-4698-9f32-c131100fd343","name":"Send message6","webhookId":"59093ce4-bf5c-438f-a5b8-a92231a64be9","credentials":{"whatsAppApi":{"id":"Jl5aH7LJ3O7m8M3p","name":"WhatsApp account"}},"disabled":true},{"parameters":{"toolDescription":"Você é um analista financeiro.\nAbaixo estão as transações do usuário recuperadas do banco de dados:\n{{ JSON.stringify($json) }}\n\nResponda a pergunta do usuário de forma resumida.\nDiga o total gasto, total ganho e o saldo final (Receitas - Despesas).\nResponda em ESPANHOL.\n\nTU TAREA: Reportar los datos EXACTOS que recibes del sistema. NO inventes números.\n\nDATOS DEL SISTEMA (JSON):\n{{ JSON.stringify($json) }}\\n\\nINSTRUCCIONES:\n1. Di el 'balance' actual como Saldo Disponible.\n2. Di el total de 'income' e 'expenses' exactos como aparecen en los datos.\n3. Si el usuario pidió 'saldo', dalo directo.\n4. Revisa 'budgets': Si 'alert' es true, avisa con ⚠️.\n5. Sé breve.","text":"={{ $json.userPrompt }}","options":{}},"type":"@n8n/n8n-nodes-langchain.agentTool","typeVersion":3,"position":[-1408,1120],"id":"2d64cbf1-c20a-463b-920b-70e0c255f6db","name":"AI Agent Tool1"},{"parameters":{"jsCode":"let totalIncome = 0;\nlet totalExpenses = 0;\n\n// Sumar valores\nfor (const item of items) {\n  const amount = parseFloat(item.json.amount) || 0;\n  const type = item.json.type;\n\n  if (type === 'income') {\n    totalIncome += amount;\n  } else if (type === 'expense') {\n    totalExpenses += amount;\n  }\n}\n\nconst balance = totalIncome - totalExpenses;\n\n// Función para formatear en Pesos Colombianos (COP)\n// Usa 'es-CO' para asegurar el formato correcto ($ 1.200.500)\nfunction formatMoney(value) {\n  return value.toLocaleString('es-CO', {\n    style: 'currency',\n    currency: 'COP',\n    minimumFractionDigits: 0, // En Colombia no se usan céntimos usualmente\n    maximumFractionDigits: 0\n  });\n}\n\n// Lógica simple para el Consejo (en Español)\nlet advice = \"\";\nif (balance < 0) {\n  advice = \"⚠️ ¡Alerta Roja! Estás gastando más de lo que ganas. Revisa tus gastos superfluos.\";\n} else if (totalExpenses > totalIncome * 0.8) {\n  advice = \"⚠️ ¡Cuidado! Ya has comprometido más del 80% de tus ingresos.\";\n} else {\n  advice = \"🏆 ¡Felicitaciones! Tus finanzas están saludables y bajo control.\";\n}\n\n// Retorna los valores formateados\nreturn [{\n  json: {\n    total_income: formatMoney(totalIncome),\n    total_expenses: formatMoney(totalExpenses),\n    balance: formatMoney(balance),\n    ai_advice_message: advice\n  }\n}];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[-368,1568],"id":"b5c65a2a-6b5f-43e8-a710-90de9a4287a3","name":"Faz a Soma"},{"parameters":{"url":"=https://finanzas.ktuche.com/transactions/","sendQuery":true,"queryParameters":{"parameters":[{"name":"limit","value":"50"},{"name":"month","value":"={{ $today.format('MM') }}"}]},"sendBody":true,"bodyParameters":{"parameters":[{"name":"amount","value":"={{ $json.amount }}\n"},{"name":"category","value":"={{ $json.category }}"}]},"options":{"allowUnauthorizedCerts":true}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.3,"position":[-592,1568],"id":"4cfec66b-4875-4c3b-a61a-1779fd2eafc8","name":"Lista de Transações"},{"parameters":{"jsCode":"// Pega o texto que a IA mandou\nconst aiOutput = items[0].json.output || \"\";\n\n// Procura pelo primeiro bloco que parece um JSON: { ... }\nconst jsonMatch = aiOutput.match(/\\{[\\s\\S]*?\\}/);\n\nif (jsonMatch) {\n  try {\n    // Tenta converter o texto encontrado em objeto real\n    const cleanData = JSON.parse(jsonMatch[0]);\n\n    // Retorna os dados limpos para os próximos nodes\n    return [{\n      json: {\n        type: cleanData.type || \"chat\", // Se não achar tipo, vira chat\n        amount: cleanData.amount || 0,\n        category: cleanData.category || \"Geral\",\n        description: cleanData.description || \"\",\n        message: cleanData.message || \"\"\n      }\n    }];\n  } catch (error) {\n    // Se der erro no JSON, assume que é só conversa\n    return [{ json: { type: \"chat\", message: aiOutput } }];\n  }\n} else {\n  // Se não achar JSON nenhum, é conversa normal\n  return [{ json: { type: \"chat\", message: aiOutput } }];\n}"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[-1040,896],"id":"08f30e9c-ccc2-4323-8c6e-58e6a2b5d369","name":"Code in JavaScript"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":3},"conditions":[{"id":"1cc3d597-9317-4518-9a3b-c0045da1e167","leftValue":"={{ $json.error }}","rightValue":"","operator":{"type":"object","operation":"notEmpty","singleValue":true}}],"combinator":"and"},"options":{}},"type":"n8n-nodes-base.if","typeVersion":2.3,"position":[-368,1280],"id":"a1fcd54e-3bc6-408a-98d4-de5b084657d3","name":"If1"},{"parame